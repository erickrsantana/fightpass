PORT=3000
NODE_ENV=development
APP_NAME=FightPass API
APP_URL=http://localhost:3000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=fightpass
DB_USER=root
DB_PASSWORD=

JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=8h

# Email SMTP - recuperacao de senha
# Padrao recomendado: Brevo SMTP ou outro provedor SMTP com camada gratuita para prototipo.
# Crie a conta, va em Transactional > SMTP e use SMTP login + SMTP key.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=FightPass <seu-email-verificado@exemplo.com>
# URL da tela redefinir-senha.html. Com Live Server no workspace raiz, este caminho costuma funcionar.
PASSWORD_RESET_URL=http://127.0.0.1:5500/fightpass-frontend/redefinir-senha.html

# Geolocalizacao por CEP
# ViaCEP e usado sem chave. Sem Google, a API tenta obter latitude/longitude pelo OpenStreetMap/Nominatim.
GOOGLE_GEOCODING_API_KEY=
OPENSTREETMAP_GEOCODING_URL=https://nominatim.openstreetmap.org/search
GEOCODING_TIMEOUT_MS=5000

CHECKIN_TOKEN_TTL_SECONDS=45
BOOKING_CANCELLATION_LIMIT_HOURS=2
